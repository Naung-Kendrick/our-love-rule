{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "roomId": { "type": "string" }
      },
      "required": ["uid", "displayName"]
    },
    "Room": {
      "title": "Room",
      "description": "A shared room for a couple",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "partner1": { "type": "string" },
        "partner2": { "type": "string" },
        "partner1Name": { "type": "string" },
        "partner2Name": { "type": "string" },
        "startDate": { "type": "string", "format": "date" }
      },
      "required": ["code", "partner1", "partner1Name"]
    },
    "Rule": {
      "title": "Rule",
      "description": "A shared rule for the couple",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isDone": { "type": "boolean" }
      },
      "required": ["title", "description", "authorId", "authorName", "createdAt", "isDone"]
    },
    "Vow": {
      "title": "Vow",
      "description": "A shared vow for the couple",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "authorId", "authorName", "createdAt"]
    },
    "Memory": {
      "title": "Memory",
      "description": "A shared memory for the couple",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "imageUrl": { "type": "string" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "date", "authorId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "Couples' rooms"
    },
    "/rooms/{roomId}/rules/{ruleId}": {
      "schema": "Rule",
      "description": "Love rules in a room"
    },
    "/rooms/{roomId}/vows/{vowId}": {
      "schema": "Vow",
      "description": "Love vows in a room"
    },
    "/rooms/{roomId}/memories/{memoryId}": {
      "schema": "Memory",
      "description": "Memories in a room"
    }
  }
}
