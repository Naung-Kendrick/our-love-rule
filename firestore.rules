rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Global Helpers
    function isSignedIn() {
      return request.auth != null; // Allow anonymous users
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (request.auth.token.email == 'sanhlutaang510237@gmail.com' || request.auth.uid == 'admin');
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName']) 
        && data.uid is string && data.uid.size() <= 128
        && data.displayName is string && (data.displayName == 'Ko' || data.displayName == 'Thet Htar')
        && (!data.keys().contains('roomId') || (data.roomId is string && data.roomId.size() <= 128));
    }

    function isValidRoom(data) {
      return data.keys().hasAll(['code', 'partner1Name', 'partner2Name'])
        && data.code is string && data.code.size() <= 20
        && data.partner1Name == 'Ko'
        && data.partner2Name == 'Thet Htar'
        && (!data.keys().contains('startDate') || (data.startDate is string && data.startDate.size() <= 20));
    }

    function isValidRule(data) {
      return data.keys().hasAll(['text', 'authorId', 'authorName', 'createdAt', 'isDone'])
        && data.text is string && data.text.size() <= 500
        && data.authorName is string && (data.authorName == 'Ko' || data.authorName == 'Thet Htar')
        && data.createdAt == request.time
        && data.isDone is bool;
    }

    function isValidVow(data) {
      return data.keys().hasAll(['text', 'authorId', 'authorName', 'createdAt'])
        && data.text is string && data.text.size() <= 2000
        && data.authorName is string && (data.authorName == 'Ko' || data.authorName == 'Thet Htar')
        && data.createdAt == request.time;
    }

    function isValidMemory(data) {
      return data.keys().hasAll(['text', 'date', 'authorId', 'createdAt'])
        && data.text is string && data.text.size() <= 1000
        && data.date is string && data.date.size() <= 20
        && data.createdAt == request.time
        && (!data.keys().contains('imageUrl') || (data.imageUrl is string && data.imageUrl.size() <= 900000));
    }

    function isRoomMember(roomId) {
      return roomId == 'ko-and-thet-htar-shared-room'; // Allow access to the fixed room
    }

    // --- Match Blocks ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
    }

    match /rooms/{roomId} {
      allow get: if isSignedIn() && (isRoomMember(roomId) || isAdmin());
      allow create: if isSignedIn() && (roomId == 'ko-and-thet-htar-shared-room'); 
      allow update: if isSignedIn() && isRoomMember(roomId) 
        && (incoming().diff(existing()).affectedKeys().hasOnly(['startDate', 'partner1Name', 'partner2Name']))
        && isValidRoom(incoming());
      
      match /rules/{ruleId} {
        allow list: if isSignedIn() && isRoomMember(roomId);
        allow get: if isSignedIn() && isRoomMember(roomId);
        allow create: if isSignedIn() && isRoomMember(roomId) && isValidRule(incoming()) && isValidId(ruleId);
        allow update: if isSignedIn() && isRoomMember(roomId)
          && (
            // Toggle done
            (incoming().diff(existing()).affectedKeys().hasOnly(['isDone']))
            ||
            // Edit own rule
            (existing().authorId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['text']))
          )
          && isValidRule(incoming());
        allow delete: if isSignedIn() && isRoomMember(roomId) && (existing().authorId == request.auth.uid || isAdmin());
      }

      match /vows/{vowId} {
        allow list: if isSignedIn() && isRoomMember(roomId);
        allow get: if isSignedIn() && isRoomMember(roomId);
        allow create: if isSignedIn() && isRoomMember(roomId) && isValidVow(incoming()) && isValidId(vowId);
        allow update: if isSignedIn() && isRoomMember(roomId) && existing().authorId == request.auth.uid
          && incoming().diff(existing()).affectedKeys().hasOnly(['text'])
          && isValidVow(incoming());
        allow delete: if isSignedIn() && isRoomMember(roomId) && (existing().authorId == request.auth.uid || isAdmin());
      }

      match /memories/{memoryId} {
        allow list: if isSignedIn() && isRoomMember(roomId);
        allow get: if isSignedIn() && isRoomMember(roomId);
        allow create: if isSignedIn() && isRoomMember(roomId) && isValidMemory(incoming()) && isValidId(memoryId);
        allow update: if isSignedIn() && isRoomMember(roomId) && existing().authorId == request.auth.uid
          && (incoming().diff(existing()).affectedKeys().hasOnly(['text', 'date', 'imageUrl']))
          && isValidMemory(incoming());
        allow delete: if isSignedIn() && isRoomMember(roomId) && (existing().authorId == request.auth.uid || isAdmin());
      }
    }
  }
}
